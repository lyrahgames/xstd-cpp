cxx.std = latest
cxx.features.modules = true

using cxx

hxx{*}: extension = hpp
ixx{*}: extension = ipp
txx{*}: extension = tpp
cxx{*}: extension = cpp
mxx{*}: extension = mpp

hxx{*}: cxx.importable = false

exe{*}: test = true

test.target = $cxx.target

# Import `xstd` by default and make it available.
#
import xstd = libxstd%lib{xstd}
